{
	"compilerOptions": {
		"target": "ES2024",
		"lib": ["ES2024"],

		"module": "ESNext",
		"moduleResolution": "Bundler",

		"strict": true,
		"skipLibCheck": true,

		"allowJs": true,
		"checkJs": false,

		"noEmit": true,

		"jsx": "react-jsx",

		"allowSyntheticDefaultImports": true,

		"isolatedModules": true,
		"resolveJsonModule": true,

		"types": ["./worker-configuration.d.ts"]
	},
	"include": ["worker-configuration.d.ts", "src/**/*.ts"],
	"exclude": ["test"]
}
