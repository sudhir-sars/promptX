{
	"name": "@xevos-ai/promptx",
	"version": "0.1.1",
	"description": "Fetch prompts from the Xevos edge",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"prompt",
		"llm",
		"ai",
		"xevos"
	],
	"devDependencies": {
		"@promptx/shared": "workspace:*",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0"
	}
}
