{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",

		"lib": ["ES2022", "DOM"],

		"rootDir": "src",
		"outDir": "dist",

		"strict": true,

		"skipLibCheck": true,
		"isolatedModules": true,

		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,

		"forceConsistentCasingInFileNames": true,

		"noEmit": true
	},
	"include": ["src"]
}
