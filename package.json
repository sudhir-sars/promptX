{
	"name": "promptx",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@9.12.0",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"type-check": "turbo run type-check",
		"deploy": "turbo run deploy"
	},
	"devDependencies": {
		"prettier": "^3.8.4",
		"turbo": "^2.3.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		]
	}
}
