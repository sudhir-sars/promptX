{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/.turbo",
      "!**/.wrangler",
      "!**/coverage",
      "!**/node_modules",
      "!**/.claude",
      "!**/*.tsbuildinfo",
      "!**/pnpm-lock.yaml",
      "!**/convex/_generated",
      "!**/worker-configuration.d.ts",
      "!**/next-env.d.ts",
      "!**/globals.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noDebugger": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error", "warn"] } },
        "noExplicitAny": "warn",
        "noMisplacedAssertion": "error"
      },
      "nursery": {
        "noFloatingPromises": "error"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useConst": "error",
        "useNodejsImportProtocol": "error",
        "noNonNullAssertion": "warn",
        "noParameterAssign": "error",
        "useTemplate": "error"
      },
      "complexity": {
        "noForEach": "off",
        "useLiteralKeys": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnknownPseudoClass": "off"
          }
        }
      }
    }
  ]
}
